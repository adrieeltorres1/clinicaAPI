generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model consultas {
  medico_id     Int
  paciente_id   Int
  data_consulta DateTime       @db.Timestamptz(6)
  id_consulta   Int            @id @default(autoincrement())
  observacoes   String?
  status        StatusConsulta @default(AGENDADO)
  medicos       medicos        @relation(fields: [medico_id], references: [id])
  pacientes     pacientes      @relation(fields: [paciente_id], references: [id])
}

model especialidades {
  id_especialidade   Int       @id @default(autoincrement())
  nome_especialidade String    @unique @db.VarChar(255)
  medicos            medicos[]
}

model medicos {
  id               Int               @id @default(autoincrement())
  nome_medico      String            @db.VarChar(255)
  crm_medico       String            @unique @db.VarChar(30)
  cpf_medico       String            @unique @db.VarChar(11)
  data_nascimento  DateTime          @db.Date
  especialidade_id Int
  Disponibilidade  Disponibilidade[]
  consultas        consultas[]
  especialidades   especialidades    @relation(fields: [especialidade_id], references: [id_especialidade], map: "fk_medicos_especialidade")
}

model pacientes {
  id              Int         @id @default(autoincrement())
  nome_paciente   String      @db.VarChar(255)
  cpf_paciente    String      @unique @db.VarChar(11)
  data_nascimento DateTime    @db.Date
  plano_id        Int
  consultas       consultas[]
  planos          planos      @relation(fields: [plano_id], references: [id_plano])
}

model planos {
  id_plano   Int         @id @default(autoincrement())
  nome_plano String      @unique
  preco      Decimal     @default(0.00)
  pacientes  pacientes[]
}

model Disponibilidade {
  id          Int     @id @default(autoincrement())
  medico_id   Int
  dia_semana  Int
  hora_inicio String
  hora_fim    String
  medicos     medicos @relation(fields: [medico_id], references: [id])
}

enum StatusConsulta {
  AGENDADO
  CONFIRMADO
  CANCELADO
  REALIZADO
}
